# -----------------------------------------------------------------------------
# Django Configuration
# -----------------------------------------------------------------------------
SECRET_KEY=django-insecure-change-this-to-a-very-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# -----------------------------------------------------------------------------
# Database Configuration (PostgreSQL)
# -----------------------------------------------------------------------------
DB_NAME=portfolio_db
DB_USER=portfolio_user
DB_PASSWORD=strong_database_password_123!
DB_HOST=db
DB_PORT=5432

# -----------------------------------------------------------------------------
# GitHub Integration (For automated static site generation & push)
# -----------------------------------------------------------------------------
# GitHub Personal Access Token with 'repo' access scope
GITHUB_TOKEN=ghp_yourpersonalaccesstokenhere
# Repository path on GitHub, e.g. "username/portfolio"
GITHUB_REPO=username/portfolio
# Branch to publish static content to
GITHUB_BRANCH=gh-pages
